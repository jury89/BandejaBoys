rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isNotifier() {
      return signedIn()
        && request.auth.token.email == 'codex@kirivoraup.resend.app'
        && request.auth.token.email_verified == true;
    }

    function isMember() {
      return signedIn() && !isNotifier();
    }

    function validAvatar() {
      return !request.resource.data.keys().hasAny(['avatarDataUrl'])
        || (request.resource.data.avatarDataUrl is string
          && request.resource.data.avatarDataUrl.size() <= 100000
          && request.resource.data.avatarDataUrl.matches(
            '^data:image/(jpeg|png|webp);base64,[A-Za-z0-9+/=]+$'
          ));
    }

    function validUserProfile(userId) {
      return request.resource.data.keys()
          .hasOnly(['id', 'displayName', 'email', 'createdAt', 'avatarDataUrl'])
        && request.resource.data.id == userId
        && request.resource.data.displayName is string
        && request.resource.data.displayName.size() >= 2
        && request.resource.data.displayName.size() <= 40
        && request.resource.data.email is string
        && request.resource.data.createdAt is number
        && validAvatar();
    }

    function validMatchRatingResponse(responseId) {
      return request.resource.data.keys().hasOnly([
          'id', 'pollId', 'slotId', 'reviewerId', 'status', 'closedAt'
        ])
        && request.resource.data.id == responseId
        && responseId == request.resource.data.pollId + '__' + request.resource.data.slotId + '__' + request.auth.uid
        && request.resource.data.pollId is string
        && request.resource.data.slotId is string
        && request.resource.data.reviewerId == request.auth.uid
        && request.resource.data.status in ['dismissed', 'submitted']
        && request.resource.data.closedAt is number;
    }

    function validMatchRating(ratingId) {
      return request.resource.data.keys().hasOnly([
          'id', 'responseId', 'pollId', 'pollTitle', 'slotId',
          'sessionStartsAt', 'sessionEndedAt', 'reviewerId', 'reviewerName',
          'revieweeId', 'revieweeName', 'score', 'createdAt'
        ])
        && request.resource.data.id == ratingId
        && ratingId == request.resource.data.responseId + '__' + request.resource.data.revieweeId
        && request.resource.data.responseId is string
        && request.resource.data.pollId is string
        && request.resource.data.pollTitle is string
        && request.resource.data.slotId is string
        && request.resource.data.sessionStartsAt is string
        && request.resource.data.sessionEndedAt is number
        && request.resource.data.reviewerId == request.auth.uid
        && request.resource.data.reviewerName is string
        && request.resource.data.revieweeId is string
        && request.resource.data.revieweeId != request.auth.uid
        && request.resource.data.revieweeName is string
        && request.resource.data.score is int
        && request.resource.data.score >= 1
        && request.resource.data.score <= 10
        && request.resource.data.createdAt is number
        && existsAfter(/databases/$(database)/documents/matchRatingResponses/$(request.resource.data.responseId))
        && getAfter(/databases/$(database)/documents/matchRatingResponses/$(request.resource.data.responseId)).data.status == 'submitted'
        && getAfter(/databases/$(database)/documents/matchRatingResponses/$(request.resource.data.responseId)).data.reviewerId == request.auth.uid
        && getAfter(/databases/$(database)/documents/matchRatingResponses/$(request.resource.data.responseId)).data.closedAt == request.resource.data.createdAt;
    }

    function validActivityEvent() {
      return request.resource.data.keys().hasOnly([
          'type', 'actorId', 'actorName', 'pollId', 'pollTitle',
          'slotId', 'slotStartsAt', 'details', 'occurredAt'
        ])
        && request.resource.data.type in [
          'poll_created', 'poll_archived', 'poll_reopened', 'poll_deleted',
          'slot_created', 'slot_rescheduled', 'slot_deleted',
          'signup_joined', 'signup_left', 'starter_substituted',
          'slot_booked', 'slot_unbooked'
        ]
        && request.resource.data.actorId == request.auth.uid
        && request.resource.data.actorName is string
        && request.resource.data.actorName.size() >= 2
        && request.resource.data.actorName.size() <= 40
        && request.resource.data.pollId is string
        && request.resource.data.pollTitle is string
        && (!request.resource.data.keys().hasAny(['slotId'])
          || request.resource.data.slotId is string)
        && (!request.resource.data.keys().hasAny(['slotStartsAt'])
          || request.resource.data.slotStartsAt is string)
        && request.resource.data.details is map
        && request.resource.data.occurredAt == request.time;
    }

    function validNotificationDelivery() {
      return request.resource.data.keys().hasOnly([
          'eventId', 'kind', 'title', 'body', 'userId', 'subscriptionId', 'sentAt'
        ])
        && request.resource.data.eventId is string
        && request.resource.data.kind in [
          'new-slots', 'slot-ready', 'booking-reminder-7d',
          'reminder-24h', 'reminder-2h', 'match-rating', 'test'
        ]
        && request.resource.data.title is string
        && request.resource.data.body is string
        && request.resource.data.userId is string
        && request.resource.data.subscriptionId is string
        && request.resource.data.sentAt == request.time;
    }

    function validSlotView() {
      return request.resource.data.keys().hasOnly([
          'pollId', 'pollTitle', 'slotId', 'slotStartsAt',
          'viewerId', 'viewerName', 'firstViewedAt', 'lastViewedAt', 'viewCount'
        ])
        && request.resource.data.pollId is string
        && request.resource.data.pollTitle is string
        && request.resource.data.slotId is string
        && request.resource.data.slotStartsAt is string
        && request.resource.data.viewerId == request.auth.uid
        && request.resource.data.viewerName is string
        && request.resource.data.viewerName.size() >= 2
        && request.resource.data.viewerName.size() <= 40
        && request.resource.data.firstViewedAt is timestamp
        && request.resource.data.lastViewedAt is timestamp
        && request.resource.data.viewCount is int
        && request.resource.data.viewCount >= 1;
    }

    match /users/{userId} {
      allow read: if isMember();
      allow create: if isMember()
        && request.auth.uid == userId
        && validUserProfile(userId);
      allow update: if isMember()
        && request.auth.uid == userId
        && validUserProfile(userId)
        && request.resource.data.email == resource.data.email
        && request.resource.data.createdAt == resource.data.createdAt
        && (request.resource.data.displayName == resource.data.displayName
          || !request.resource.data.displayName.matches('.*[Ee][Vv][Ii].*'));
      allow delete: if false;
    }

    match /polls/{pollId} {
      allow read: if isMember() || isNotifier();
      allow create: if isMember()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.title is string
        && request.resource.data.slots is list
        && request.resource.data.slots.size() > 0
        && request.resource.data.slots.size() <= 14;
      allow update: if isMember()
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['slots', 'status', 'updatedAt']);
      allow delete: if isMember() && resource.data.createdBy == request.auth.uid;
    }

    match /pushSubscriptions/{subscriptionId} {
      allow get: if isNotifier() || (isMember() && resource.data.userId == request.auth.uid);
      allow list: if isNotifier();
      allow create: if isMember()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.endpoint is string
        && request.resource.data.keys is map;
      allow update: if isMember()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.endpoint == resource.data.endpoint
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['userId', 'keys', 'expirationTime', 'createdAt', 'updatedAt']);
      allow delete: if isNotifier() || (isMember() && resource.data.userId == request.auth.uid);
    }

    match /notificationDeliveries/{deliveryId} {
      allow read: if isNotifier();
      allow create: if isNotifier() && validNotificationDelivery();
      allow update, delete: if false;
    }

    match /activityEvents/{eventId} {
      allow read: if isMember();
      allow create: if isMember() && validActivityEvent();
      allow update, delete: if false;
    }

    match /slotViews/{viewId} {
      allow read: if isMember();
      allow create: if isMember()
        && validSlotView()
        && request.resource.data.firstViewedAt == request.time
        && request.resource.data.lastViewedAt == request.time
        && request.resource.data.viewCount == 1;
      allow update: if isMember()
        && validSlotView()
        && request.resource.data.pollId == resource.data.pollId
        && request.resource.data.slotId == resource.data.slotId
        && request.resource.data.viewerId == resource.data.viewerId
        && request.resource.data.firstViewedAt == resource.data.firstViewedAt
        && request.resource.data.lastViewedAt == request.time
        && request.resource.data.viewCount == resource.data.viewCount + 1
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'pollTitle', 'slotStartsAt', 'viewerName', 'lastViewedAt', 'viewCount'
        ]);
      allow delete: if false;
    }

    match /matchRatingResponses/{responseId} {
      allow read: if isNotifier() || (isMember() && resource.data.reviewerId == request.auth.uid);
      allow create: if isMember() && validMatchRatingResponse(responseId);
      allow update, delete: if false;
    }

    match /matchRatings/{ratingId} {
      allow read: if isMember() && resource.data.reviewerId == request.auth.uid;
      allow create: if isMember() && validMatchRating(ratingId);
      allow update, delete: if false;
    }
  }
}
