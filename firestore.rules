rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isNotifier() {
      return signedIn()
        && request.auth.token.email == 'codex@kirivoraup.resend.app'
        && request.auth.token.email_verified == true;
    }

    function isMember() {
      return signedIn() && !isNotifier();
    }

    function validAvatar() {
      return !request.resource.data.keys().hasAny(['avatarDataUrl'])
        || (request.resource.data.avatarDataUrl is string
          && request.resource.data.avatarDataUrl.size() <= 100000
          && request.resource.data.avatarDataUrl.matches(
            '^data:image/(jpeg|png|webp);base64,[A-Za-z0-9+/=]+$'
          ));
    }

    function validUserProfile(userId) {
      return request.resource.data.keys()
          .hasOnly(['id', 'displayName', 'email', 'createdAt', 'avatarDataUrl'])
        && request.resource.data.id == userId
        && request.resource.data.displayName is string
        && request.resource.data.displayName.size() >= 2
        && request.resource.data.displayName.size() <= 40
        && request.resource.data.email is string
        && request.resource.data.createdAt is number
        && validAvatar();
    }

    match /users/{userId} {
      allow read: if isMember();
      allow create: if isMember()
        && request.auth.uid == userId
        && validUserProfile(userId);
      allow update: if isMember()
        && request.auth.uid == userId
        && validUserProfile(userId)
        && request.resource.data.email == resource.data.email
        && request.resource.data.createdAt == resource.data.createdAt
        && (request.resource.data.displayName == resource.data.displayName
          || !request.resource.data.displayName.matches('.*[Ee][Vv][Ii].*'));
      allow delete: if false;
    }

    match /polls/{pollId} {
      allow read: if isMember() || isNotifier();
      allow create: if isMember()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.title is string
        && request.resource.data.slots is list
        && request.resource.data.slots.size() > 0
        && request.resource.data.slots.size() <= 14;
      allow update: if isMember()
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['slots', 'status', 'updatedAt']);
      allow delete: if isMember() && resource.data.createdBy == request.auth.uid;
    }

    match /pushSubscriptions/{subscriptionId} {
      allow get: if isNotifier() || (isMember() && resource.data.userId == request.auth.uid);
      allow list: if isNotifier();
      allow create: if isMember()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.endpoint is string
        && request.resource.data.keys is map;
      allow update: if isMember()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.endpoint == resource.data.endpoint
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['userId', 'keys', 'expirationTime', 'createdAt', 'updatedAt']);
      allow delete: if isNotifier() || (isMember() && resource.data.userId == request.auth.uid);
    }

    match /notificationDeliveries/{deliveryId} {
      allow read, write: if isNotifier();
    }
  }
}
